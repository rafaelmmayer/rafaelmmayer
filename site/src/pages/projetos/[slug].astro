---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projetos', ({ data }) => data.published !== false);

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} — Rafael Mayer`} description={project.data.description}>
  <article class="prose">
    <a class="back" href="/projetos/">← projetos</a>
    <p class="kicker">{project.data.status ?? 'projeto'}</p>
    <h1>{project.data.title}</h1>
    <p class="lead">{project.data.description}</p>
    {project.data.tags?.length ? (
      <p class="post-meta">{project.data.tags.join(' · ')}</p>
    ) : null}
    <Content />
  </article>
</BaseLayout>
